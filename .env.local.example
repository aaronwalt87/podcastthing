# Vercel Blob — auto-added when you connect a Blob store in Vercel dashboard
BLOB_READ_WRITE_TOKEN=

# Upstash Redis — auto-added when you install from Vercel Marketplace
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin password
ADMIN_PASSWORD=

# News cron — generate with: openssl rand -hex 32
CRON_SECRET=

# Optional: news cache TTL in seconds (default 7200 = 2h; use 90000 for Vercel free tier)
# NEWS_TTL_SECONDS=7200
